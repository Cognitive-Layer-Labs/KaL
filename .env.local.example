# ── Oracle proxy (server-side only, never exposed to browser) ─────────────────
# Local dev: http://localhost:3000  |  Production: https://your-oracle-domain.com
POCW_ORACLE_BASE_URL="http://localhost:3000"
# Must match POCW_API_KEY in PoCW/.env. Leave empty for local dev (no auth).
POCW_API_KEY=""

# ── Web3Modal project ID ──────────────────────────────────────────────────────
# Get from cloud.walletconnect.com. Leave empty to use MetaMask-only (no WC modal).
NEXT_PUBLIC_WC_PROJECT_ID=""

# ── Contract addresses ────────────────────────────────────────────────────────
# Local dev: copy from PoCW/deployments/localhost.json after npm run deploy:local
# Testnet:   copy from PoCW/deployments/base-sepolia.json after npm run deploy:base-sepolia
NEXT_PUBLIC_SBT_ADDRESS=""
NEXT_PUBLIC_CONTROLLER_ADDRESS=""
NEXT_PUBLIC_KAL_ADDRESS=""

# ── Chain ─────────────────────────────────────────────────────────────────────
# 84532 = Base Sepolia  |  31337 = Hardhat local
NEXT_PUBLIC_CHAIN_ID="31337"
